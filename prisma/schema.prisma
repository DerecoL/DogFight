// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  account      String   @unique
  passwordHash String
  nickname     String?
  createdAt    DateTime @default(now())
  runs         Run[]
}

model Run {
  id          String   @id @default(cuid())
  userId      String
  dogType     String
  wins        Int      @default(0)
  losses      Int      @default(0)
  round       Int      @default(0)
  luckyNumber Int?
  gold        Int      @default(10)
  phase       String   @default("SHOP")
  status      String   @default("ACTIVE")
  shopType    String   @default("GENERAL")
  shopItems   String   @default("[]")
  choices     String   @default("[]")
  classRewardChoices String @default("[]")
  relicChoices String   @default("[]")
  relics      String   @default("[]")
  refreshCost Int      @default(1)
  matchedGhost String?
  lastBattle  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  items       ItemInstance[]
  battles     BattleLog[]
  dogfightParticipant DogfightParticipant?
}

model ItemInstance {
  id        String   @id @default(cuid())
  runId     String
  defId     String
  quality   String   @default("BRONZE")
  area      String
  x         Int
  y         Int
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model GhostSnapshot {
  id        String   @id @default(cuid())
  runId     String?
  userId    String?
  name      String
  dogType   String
  luckyNumber Int?
  round     Int
  wins      Int
  losses    Int
  gold      Int
  items     String
  relics    String   @default("[]")
  seed      String
  createdAt DateTime @default(now())

  @@index([round, wins, losses])
}

model ApexEntry {
  id            String   @id @default(cuid())
  userId        String?
  sourceRunId   String?  @unique
  name          String
  dogType       String
  luckyNumber   Int?
  round         Int
  wins          Int
  losses        Int
  items         String
  relics        String   @default("[]")
  rank          Int      @unique
  challengeWins Int      @default(0)
  isSeed        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([rank])
}

model BattleLog {
  id        String   @id @default(cuid())
  runId     String
  ghostId   String?
  result    String
  log       String
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model DogfightRoom {
  id                  String   @id @default(cuid())
  hostUserId          String
  status              String   @default("WAITING")
  currentRound        Int      @default(0)
  maxPlayers          Int      @default(8)
  readyDeadline       DateTime?
  winnerParticipantId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  participants DogfightParticipant[]
  battles      DogfightBattle[]

  @@index([status])
  @@index([hostUserId])
}

model DogfightParticipant {
  id              String   @id @default(cuid())
  roomId          String
  userId          String
  runId           String   @unique
  nickname        String
  isHost          Boolean  @default(false)
  ready           Boolean  @default(false)
  eliminated      Boolean  @default(false)
  eliminatedRound Int?
  placement       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  room DogfightRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  run  Run          @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model DogfightBattle {
  id             String   @id @default(cuid())
  roomId         String
  round          Int
  participantAId String
  participantBId String?
  opponentKind   String
  winnerSide     String
  winnerParticipantId String?
  result         String
  createdAt      DateTime @default(now())

  room DogfightRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, round])
  @@index([participantAId])
  @@index([participantBId])
}
