// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  account      String   @unique
  passwordHash String
  nickname     String?
  createdAt    DateTime @default(now())
  runs         Run[]
  seasonSummaries SeasonPlayerSummary[]
  ladderProfiles LadderProfile[]
  ladderSettlements LadderSettlement[]
  wallet       AccountWallet?
  currencyLedger CurrencyLedger[]
  achievementProgress AchievementProgress[]
  dailyTaskSets DailyTaskSet[]
  cosmeticInventory CosmeticInventory[]
  cosmeticEquips CosmeticEquip[]
  identities   UserIdentity[]
}

model UserIdentity {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  unionId        String?
  sessionKey     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([unionId])
}

model Season {
  id        String   @id
  name      String
  status    String   @default("ACTIVE")
  startedAt DateTime @default(now())
  endedAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  summaries SeasonPlayerSummary[]

  @@index([status])
}

model SeasonPlayerSummary {
  id                 String   @id @default(cuid())
  userId             String
  seasonId           String
  seasonName         String
  ladderTier         String?
  ladderScore        Int?
  ladderHighestTier  String?
  ladderGamesPlayed  Int      @default(0)
  ladderTotalWins    Int      @default(0)
  ladderTotalLosses  Int      @default(0)
  dogKingRank        Int?
  apexRank           Int?
  apexDogType        String?
  apexWins           Int?
  apexLosses         Int?
  apexRound          Int?
  apexChallengeWins  Int?
  apexSnapshot       String?
  createdAt          DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, apexRank])
  @@index([userId, createdAt])
}

model Run {
  id          String   @id @default(cuid())
  userId      String
  seasonId    String   @default("season-1")
  mode        String   @default("CASUAL")
  dogType     String
  wins        Int      @default(0)
  losses      Int      @default(0)
  round       Int      @default(0)
  luckyNumber Int?
  gold        Int      @default(10)
  phase       String   @default("SHOP")
  status      String   @default("ACTIVE")
  shopType    String   @default("GENERAL")
  shopItems   String   @default("[]")
  choices     String   @default("[]")
  classRewardChoices String @default("[]")
  enchantChoices String  @default("[]")
  enchantThirdLossGranted Boolean @default(false)
  potionChoices String   @default("[]")
  relicChoices String   @default("[]")
  relics      String   @default("[]")
  refreshCost Int      @default(1)
  matchedGhost String?
  lastBattle  String?
  mapState    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  items       ItemInstance[]
  battles     BattleLog[]
  dogfightParticipant DogfightParticipant?
  ladderSettlement LadderSettlement?
}

model ItemInstance {
  id        String   @id @default(cuid())
  runId     String
  defId     String
  quality   String   @default("BRONZE")
  area      String
  x         Int
  y         Int
  enchant   String?
  triggerDiceOverride String?
  sellBonus Int      @default(0)
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model GhostSnapshot {
  id        String   @id @default(cuid())
  runId     String?
  userId    String?
  seasonId  String   @default("season-1")
  mode      String   @default("CASUAL")
  name      String
  dogType   String
  luckyNumber Int?
  round     Int
  wins      Int
  losses    Int
  gold      Int
  items     String
  relics    String   @default("[]")
  seed      String
  createdAt DateTime @default(now())

  @@index([round, wins, losses])
  @@index([mode, round, wins, losses])
}

model LadderProfile {
  id          String   @id @default(cuid())
  userId      String
  seasonId    String
  tier        String   @default("BRONZE")
  score       Int      @default(0)
  highestTier String   @default("BRONZE")
  gamesPlayed Int      @default(0)
  totalWins   Int      @default(0)
  totalLosses Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlements LadderSettlement[]

  @@unique([userId, seasonId])
  @@index([seasonId, tier, score])
}

model LadderSettlement {
  id          String   @id @default(cuid())
  userId      String
  profileId   String
  runId       String   @unique
  seasonId    String
  beforeTier  String
  beforeScore Int
  afterTier   String
  afterScore  Int
  delta       Int
  rawDelta    Int
  baseScore   Int
  tierTax     Int
  lossPenalty Int
  perfectBonus Int
  newbieProtection Int
  wins        Int
  losses      Int
  createdAt   DateTime @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     LadderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  run         Run           @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([seasonId, afterTier, afterScore])
  @@index([userId, seasonId])
}

model ApexEntry {
  id            String   @id @default(cuid())
  userId        String?
  sourceRunId   String?
  seasonId      String   @default("season-1")
  boardType     String   @default("OVERALL")
  boardKey      String   @default("default")
  name          String
  dogType       String
  luckyNumber   Int?
  round         Int
  wins          Int
  losses        Int
  items         String
  relics        String   @default("[]")
  rank          Int
  challengeWins Int      @default(1)
  isSeed        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([seasonId, sourceRunId, boardType])
  @@unique([seasonId, boardType, boardKey, rank])
  @@index([userId])
  @@index([seasonId, boardType, boardKey, rank])
}

model BattleLog {
  id        String   @id @default(cuid())
  runId     String
  ghostId   String?
  result    String
  log       String
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model DogfightRoom {
  id                  String   @id @default(cuid())
  hostUserId          String
  status              String   @default("WAITING")
  phase               String   @default("LOBBY")
  currentRound        Int      @default(0)
  maxPlayers          Int      @default(8)
  targetPlayerCount   Int      @default(8)
  readyDeadline       DateTime?
  phaseDeadline       DateTime?
  winnerParticipantId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  participants DogfightParticipant[]
  battles      DogfightBattle[]

  @@index([status])
  @@index([hostUserId])
}

model DogfightParticipant {
  id              String   @id @default(cuid())
  roomId          String
  userId          String?
  runId           String?  @unique
  nickname        String
  kind            String   @default("PLAYER")
  isHost          Boolean  @default(false)
  ready           Boolean  @default(false)
  eliminated      Boolean  @default(false)
  eliminatedRound Int?
  placement       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  room DogfightRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  run  Run?         @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model DogfightBattle {
  id             String   @id @default(cuid())
  roomId         String
  round          Int
  participantAId String
  participantBId String?
  opponentKind   String
  winnerSide     String
  winnerParticipantId String?
  result         String
  createdAt      DateTime @default(now())

  room DogfightRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, round])
  @@index([participantAId])
  @@index([participantBId])
}

model AccountWallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Int      @default(0)
  dailyEarned Int      @default(0)
  dailyKey    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CurrencyLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  balanceAfter Int
  source    String
  refId     String?
  dailyKey  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, dailyKey])
}

model AchievementProgress {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  progress      Int      @default(0)
  completedAt   DateTime?
  claimedAt     DateTime?
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, completedAt, claimedAt])
}

model DailyTaskSet {
  id          String   @id @default(cuid())
  userId      String
  dateKey     String
  refreshUsed Boolean  @default(false)
  tasks       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}

model CosmeticInventory {
  id            String   @id @default(cuid())
  userId        String
  catalogItemId String
  acquiredAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, catalogItemId])
  @@index([userId])
}

model CosmeticEquip {
  id            String   @id @default(cuid())
  userId        String
  slot          String
  catalogItemId String
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slot])
}

model ShopCatalogOverride {
  id            String   @id @default(cuid())
  catalogItemId String   @unique
  listed        Boolean  @default(true)
  price         Int?
  section       String?
  limitPerUser  Int?
  rotationKey   String?
  sku           String?
  purchaseType  String?
  source        String   @default("DB_OVERRIDE")
  updatedAt     DateTime @updatedAt
}
