NODE_ENV=production
DOMAIN=example.com

POSTGRES_DB=dogfight
POSTGRES_USER=dogfight
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://dogfight:change-this-postgres-password@postgres:5432/dogfight?schema=public

JWT_SECRET=change-this-to-a-long-random-secret

TAPTAP_MINIAPP_ID=
TAPTAP_MINIAPP_SECRET=
TAPTAP_MINIAPP_REGION=cn

BACKUP_DIR=/opt/dogfight/backups
LOCAL_BACKUP_RETENTION_HOURS=72
OFFSITE_BACKUP_RETENTION_DAYS=30
COS_BUCKET=
COS_REGION=
COS_SECRET_ID=
COS_SECRET_KEY=
ALERT_WEBHOOK_URL=
