{
  "name": "dogfight",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pglite-server --db=memory:// --max-connections=20 --include-database-url --run \"node scripts/start-local-dev.mjs\"",
    "dev:app": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "guard:chains": "tsx scripts/battle-chain-guard.ts",
    "build": "npm run guard:chains && tsc -b && vite build && tsx scripts/package-click-index.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "node scripts/init-db.cjs",
    "test": "vitest run --exclude src/server/api.test.ts && vitest run src/server/api.test.ts --maxConcurrency=1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.1.6",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.16.0",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "description": "DogFight is a React/Vite game with a Fastify API and Prisma persistence.",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DerecoL/DogFight.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DerecoL/DogFight/issues"
  },
  "homepage": "https://github.com/DerecoL/DogFight#readme"
}
